{
  "name": "svelte-prism",
  "version": "1.0.0",
  "description": "Prismjs for Svelte",
  "scripts": {
    "clean-lib": "del-cli lib/*",
    "copy:package:cjs": "copyfiles --up 1 cjs/* lib/cjs",
    "copy:package": "copyfiles package.json lib",
    "copy:src": "copyfiles --up 2 src/lib/**/* lib/src",
    "copy:cjs": "copyfiles --up 2 src/lib/**/!(*.ts) lib/cjs",
    "copy": "copyfiles --up 2 src/lib/**/!(*.ts) lib",
    "tsc": "tsc -p tsconfig.lib.json",
    "tsc:cjs": "tsc -p tsconfig.lib.cjs.json",
    "build": "npm-run-all --parallel copy:package copy:package:cjs copy copy:cjs copy:src tsc tsc:cjs",
    "lib": "npm run clean-lib && npm run build",
    "dev": "npm run clean-lib && nodemon --watch src -e ts --exec \"npm run build\"",
    "prepublish": "npm run lib",
    "publish": "npm publish ./lib",
    "test": "echo \"Error: no test specified\"",
    "semantic-release": "semantic-release"
  },
	"type": "module",
	"exports": {
		".": {
			"import": "./index.js",
			"require": "./cjs/index.js"
		}
	},
  "repository": {
    "type": "git",
    "url": "https://github.com/jakobrosenberg/svelte-prism.git"
  },
  "keywords": [
    "prism",
    "prismjs",
    "svelte",
    "code",
    "highlight"
  ],
  "author": "Jakob Rosenberg",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jakobrosenberg/svelte-prism/issues"
  },
  "homepage": "https://github.com/jakobrosenberg/svelte-prism#readme",
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "del-cli": "^4.0.0",
    "nodemon": "^2.0.7",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@types/prismjs": "^1.16.5",
    "prism-svelte": "^0.4.7",
    "prismjs": "^1.23.0",
    "svelte": "^3.38.3",
    "typescript": "^4.3.4"
  }
}
